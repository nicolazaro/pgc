<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Observatorio de Prospectiva y Gestión del Conocimiento</title>
    <!-- Tailwind CSS para diseño moderno -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); }
        .card-gradient { background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">

    <!-- Navegación -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <i data-lucide="eye" class="text-indigo-600 w-8 h-8"></i>
                <span class="font-bold text-xl tracking-tight">PROSPECTIVA<span class="text-indigo-600">.AR</span></span>
            </div>
            <div id="country-selector" class="flex gap-2">
                <!-- Los botones de países se generarán aquí -->
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <header class="bg-white border-b border-slate-200 py-12">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div class="max-w-2xl">
                    <h1 id="main-title" class="text-4xl font-extrabold text-slate-900 mb-4">Relevamiento: Argentina</h1>
                    <p id="main-description" class="text-lg text-slate-600 leading-relaxed">
                        Exploración granular de los nodos de pensamiento estratégico y gestión del conocimiento.
                    </p>
                </div>
                <div class="bg-indigo-50 border border-indigo-100 p-4 rounded-xl text-indigo-800 text-sm italic">
                    <i data-lucide="info" class="w-4 h-4 inline-block mr-1"></i>
                    Fase de investigación actual: <span class="font-bold">Latinoamérica</span>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-10 space-y-12">
        
        <!-- Grid de Categorías -->
        <section id="categories-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Se generarán dinámicamente -->
        </section>

        <!-- Buscador y Tabla -->
        <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6 bg-slate-50/50 border-b border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4">
                <h2 class="text-xl font-bold flex items-center gap-2">
                    <i data-lucide="database" class="w-5 h-5 text-indigo-600"></i>
                    Base de Datos Granular
                </h2>
                <div class="relative w-full md:w-96">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                    <input type="text" id="table-search" placeholder="Buscar por apellido, entidad o área..." 
                        class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider font-semibold">
                            <th class="px-6 py-4">Entidad</th>
                            <th class="px-6 py-4">Investigador / Referente</th>
                            <th class="px-6 py-4">Área de Interés</th>
                            <th class="px-6 py-4 text-center">Docs</th>
                            <th class="px-6 py-4">Localización</th>
                        </tr>
                    </thead>
                    <tbody id="data-table-body" class="divide-y divide-slate-100">
                        <!-- Filas generadas dinámicamente -->
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <footer class="bg-slate-900 text-slate-400 py-12 mt-20">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-sm font-medium tracking-widest uppercase mb-4">Investigación en Desarrollo</p>
            <p class="max-w-xl mx-auto text-xs leading-relaxed opacity-60">
                Este relevamiento es una herramienta colaborativa para mapear las capacidades de anticipación estratégica y capital intelectual en la región.
            </p>
        </div>
    </footer>

    <script>
        // --- BASE DE DATOS MODULAR ---
        // Puedes agregar más países copiando este bloque de Argentina
        const DATA_RELEVAMIENTO = {
            "Argentina": {
                descripcion: "Fuerte tradición en prospectiva iniciada con el Modelo Bariloche. Nodos consolidados en Cuyo, Buenos Aires y redes técnicas estatales.",
                categorias: [
                    { titulo: "Academia", icono: "book", items: ["UBA - PAEF", "UNGS - Maestría GCTI", "UNCUYO - CEP"] },
                    { titulo: "Estado", icono: "building-2", items: ["CIECTI", "INTA - CIEP", "INTI - Vigilancia"] },
                    { titulo: "Redes", icono: "users", items: ["The Millennium Project", "RIBER", "RAEF"] },
                    { titulo: "Consultoría", icono: "briefcase", items: ["Paradigma", "Practia", "Midas"] }
                ],
                registros: [
                    { entidad: "UBA", apellido: "Patrouilleau", nombre: "Mercedes", area: "Planificación estratégica", docs: true, ciudad: "CABA" },
                    { entidad: "CIECTI", apellido: "Porta", nombre: "Fernando", area: "Política CTI", docs: true, ciudad: "CABA" },
                    { entidad: "CEP Cuyo", apellido: "Ragno", nombre: "Luis", area: "Estudios Futuro", docs: true, ciudad: "Mendoza" },
                    { entidad: "INTA", apellido: "Anastasio", nombre: "Mario", area: "Prospectiva Agro", docs: false, ciudad: "CABA" },
                    { entidad: "Millennium Project", apellido: "Gutiérrez", nombre: "Miguel", area: "Seguridad Global", docs: true, ciudad: "CABA" },
                    { entidad: "UNGS", apellido: "Yoguel", nombre: "Gabriel", area: "Economía Innovación", docs: true, ciudad: "Buenos Aires" },
                    { entidad: "UNCUYO", apellido: "Vitale", nombre: "Javier", area: "Prospectiva Territorial", docs: true, ciudad: "Mendoza" }
                ]
            }
            // Agrega "Uruguay": { ... } aquí en el futuro
        };

        let currentCountry = "Argentina";

        function renderAll() {
            const data = DATA_RELEVAMIENTO[currentCountry];
            
            // Actualizar Títulos
            document.getElementById('main-title').innerText = `Relevamiento: ${currentCountry}`;
            document.getElementById('main-description').innerText = data.descripcion;

            // Render Categorías
            const grid = document.getElementById('categories-grid');
            grid.innerHTML = data.categorias.map(cat => `
                <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:border-indigo-300 transition-colors">
                    <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-lg flex items-center justify-center mb-4">
                        <i data-lucide="${cat.icono}"></i>
                    </div>
                    <h3 class="font-bold text-lg mb-2">${cat.titulo}</h3>
                    <ul class="text-sm text-slate-500 space-y-1">
                        ${cat.items.map(i => `<li>• ${i}</li>`).join('')}
                    </ul>
                </div>
            `).join('');

            // Render Tabla
            renderTable("");
            
            // Inicializar Iconos
            lucide.createIcons();
        }

        function renderTable(filter) {
            const tbody = document.getElementById('data-table-body');
            const data = DATA_RELEVAMIENTO[currentCountry].registros;
            
            const filtered = data.filter(r => 
                r.apellido.toLowerCase().includes(filter.toLowerCase()) ||
                r.entidad.toLowerCase().includes(filter.toLowerCase()) ||
                r.area.toLowerCase().includes(filter.toLowerCase())
            );

            tbody.innerHTML = filtered.map(r => `
                <tr class="hover:bg-indigo-50/30 transition-colors group">
                    <td class="px-6 py-4 font-semibold text-indigo-600">${r.entidad}</td>
                    <td class="px-6 py-4">
                        <div class="text-slate-900 font-medium">${r.apellido}, ${r.nombre}</div>
                    </td>
                    <td class="px-6 py-4 text-sm text-slate-600">${r.area}</td>
                    <td class="px-6 py-4 text-center">
                        ${r.docs ? '<i data-lucide="check-circle" class="w-4 h-4 text-green-500 mx-auto"></i>' : '<i data-lucide="circle" class="w-4 h-4 text-slate-200 mx-auto"></i>'}
                    </td>
                    <td class="px-6 py-4 text-sm text-slate-400">
                        <i data-lucide="map-pin" class="w-3 h-3 inline mr-1"></i> ${r.ciudad}
                    </td>
                </tr>
            `).join('');
            
            lucide.createIcons();
        }

        // Buscador
        document.getElementById('table-search').addEventListener('input', (e) => {
            renderTable(e.target.value);
        });

        // Selector de países (por si agregas más)
        const selector = document.getElementById('country-selector');
        Object.keys(DATA_RELEVAMIENTO).forEach(pais => {
            const btn = document.createElement('button');
            btn.className = "px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider transition-all " + 
                            (pais === currentCountry ? "bg-indigo-600 text-white shadow-lg shadow-indigo-200" : "bg-white text-slate-400 hover:text-indigo-600");
            btn.innerText = pais;
            btn.onclick = () => {
                currentCountry = pais;
                renderAll();
            };
            selector.appendChild(btn);
        });

        // Inicio
        window.onload = renderAll;
    </script>
</body>
</html>
